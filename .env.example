# Supabase Configuration
# Get these values from: https://app.supabase.com/project/_/settings/api

# Frontend Environment Variables (exposed to client-side code)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend Environment Variables (server-only, never expose to client)
# Keep these SECRET - never commit to git!
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Google OAuth (if using OAuth login)
# VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Optional: Gemini API Key for AI features
# GEMINI_API_KEY=your-gemini-api-key
